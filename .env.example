# Copy to backend/.env and fill in. Never commit the real .env.

# --- Generation (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001  # fast + cheap; swap to claude-sonnet-4-6 for max quality

# --- Pinecone (integrated embedding: index created with a hosted model,
#     so no separate embedding key is needed) ---
PINECONE_API_KEY=pc-...
PINECONE_INDEX=benefits-rag

# --- Backend auth (shared secret between Add-on and backend) ---
BACKEND_SHARED_SECRET=change-me-to-a-long-random-string
